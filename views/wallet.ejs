<!-- Wallet Page -->
<section class="max-w-7xl mx-auto px-4 py-12">
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold mb-4">Connect Your Wallet</h1>
    <p class="text-white/50 max-w-xl mx-auto">Link your Web3 wallet to unlock full trading features, view on-chain balances, and manage your digital assets securely.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
    <!-- Wallet Connection Panel -->
    <div class="glass-card-strong p-8">
      <div id="walletConnectPanel">
        <h2 class="text-xl font-semibold mb-2">Choose Wallet</h2>
        <p class="text-white/40 text-sm mb-8">Select your preferred wallet provider to connect</p>

        <!-- MetaMask -->
        <button onclick="connectMetaMask()" class="wallet-btn group">
          <img src="https://upload.wikimedia.org/wikipedia/commons/3/36/MetaMask_Fox.svg" alt="MetaMask" class="w-9 h-9" onerror="this.style.display='none'">
          <div class="w-9 h-9 rounded-2xl bg-orange-500/20 flex items-center justify-center text-orange-500 text-xl hidden" id="mmFallback">
            <i class="fas fa-fox"></i>
          </div>
          <div class="text-left flex-1">
            <p class="font-semibold">MetaMask</p>
            <p class="text-white/40 text-xs">Browser Extension • Mobile</p>
          </div>
          <i class="fas fa-chevron-right text-white/30 group-hover:text-[#00ff88] transition-colors"></i>
        </button>

        <!-- WalletConnect -->
        <button onclick="connectWalletConnect()" class="wallet-btn group">
          <div class="w-9 h-9 rounded-2xl bg-blue-500/20 flex items-center justify-center text-blue-500 text-2xl">
            <i class="fas fa-qrcode"></i>
          </div>
          <div class="text-left flex-1">
            <p class="font-semibold">WalletConnect</p>
            <p class="text-white/40 text-xs">Scan with any mobile wallet</p>
          </div>
          <i class="fas fa-chevron-right text-white/30 group-hover:text-[#00ff88] transition-colors"></i>
        </button>

        <!-- Trust Wallet -->
        <button onclick="connectTrustWallet()" class="wallet-btn group">
          <div class="w-9 h-9 rounded-2xl bg-[#00ff88]/20 flex items-center justify-center text-[#00ff88] text-2xl">
            <i class="fas fa-shield-alt"></i>
          </div>
          <div class="text-left flex-1">
            <p class="font-semibold">Trust Wallet</p>
            <p class="text-white/40 text-xs">Mobile-first • Multi-chain</p>
          </div>
          <i class="fas fa-chevron-right text-white/30 group-hover:text-[#00ff88] transition-colors"></i>
        </button>

        <!-- Coinbase Wallet -->
        <button onclick="connectCoinbase()" class="wallet-btn group">
          <div class="w-9 h-9 rounded-2xl bg-blue-600/20 flex items-center justify-center text-blue-400 text-2xl">
            <i class="fas fa-coins"></i>
          </div>
          <div class="text-left flex-1">
            <p class="font-semibold">Coinbase Wallet</p>
            <p class="text-white/40 text-xs">Secure &amp; easy to use</p>
          </div>
          <i class="fas fa-chevron-right text-white/30 group-hover:text-[#00ff88] transition-colors"></i>
        </button>
      </div>

      <!-- Connected State -->
      <div id="walletConnectedPanel" class="hidden">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-2xl bg-[#00ff88]/20 flex items-center justify-center text-[#00ff88]">
            <i class="fas fa-check text-2xl"></i>
          </div>
          <div>
            <h2 class="text-xl font-semibold">Wallet Connected</h2>
            <p class="text-white/40 text-sm">You now have full on-chain access</p>
          </div>
        </div>

        <div class="space-y-4">
          <!-- Address -->
          <div class="p-4 rounded-2xl bg-white/5">
            <p class="text-white/40 text-xs uppercase tracking-widest mb-1">Wallet Address</p>
            <div class="flex items-center gap-3">
              <p class="font-mono text-sm break-all flex-1" id="walletAddress">—</p>
              <button onclick="copyAddress()" class="text-white/40 hover:text-[#00ff88] transition-colors flex items-center gap-1 text-sm">
                <i class="fas fa-copy"></i>
                <span class="hidden sm:inline">Copy</span>
              </button>
            </div>
          </div>

          <!-- Native Balance -->
          <div class="p-4 rounded-2xl bg-white/5">
            <p class="text-white/40 text-xs uppercase tracking-widest mb-1" id="balanceLabel">Native Balance</p>
            <p class="text-3xl font-bold font-mono text-[#00ff88]" id="nativeBalance">—</p>
          </div>

          <!-- Current Network -->
          <div class="p-4 rounded-2xl bg-white/5">
            <p class="text-white/40 text-xs uppercase tracking-widest mb-1">Current Network</p>
            <div class="flex items-center gap-2">
              <span class="live-dot"></span>
              <p class="font-semibold" id="currentNetwork">—</p>
            </div>
          </div>

          <!-- Switch Network -->
          <div>
            <p class="text-white/40 text-xs uppercase tracking-widest mb-3">Switch Network</p>
            <div class="grid grid-cols-3 gap-3" id="networkButtons">
              <!-- Populated by JS for dynamic symbols -->
            </div>
          </div>
        </div>

        <button onclick="disconnectWallet()" class="btn-outline w-full mt-8 py-3 border-red-500/50 text-red-400 hover:bg-red-500/10">
          <i class="fas fa-unlink mr-2"></i> Disconnect Wallet
        </button>
      </div>
    </div>

    <!-- Side Content -->
    <div class="space-y-6">
      <!-- Why Connect -->
      <div class="glass-card p-6">
        <h3 class="text-sm font-semibold text-white/40 uppercase tracking-widest mb-4">Why Connect?</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-2xl bg-[#00ff88]/10 flex items-center justify-center text-[#00ff88] text-xl mt-0.5"><i class="fas fa-bolt"></i></div>
            <div><p class="font-medium text-sm">Instant Trading</p><p class="text-white/40 text-xs">Execute swaps directly from your wallet</p></div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-2xl bg-[#00ff88]/10 flex items-center justify-center text-[#00ff88] text-xl mt-0.5"><i class="fas fa-shield-alt"></i></div>
            <div><p class="font-medium text-sm">Self-Custody</p><p class="text-white/40 text-xs">You keep full control of your keys</p></div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-2xl bg-[#00ff88]/10 flex items-center justify-center text-[#00ff88] text-xl mt-0.5"><i class="fas fa-chart-pie"></i></div>
            <div><p class="font-medium text-sm">Portfolio Sync</p><p class="text-white/40 text-xs">Real-time on-chain + exchange balances</p></div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-2xl bg-[#00ff88]/10 flex items-center justify-center text-[#00ff88] text-xl mt-0.5"><i class="fas fa-globe"></i></div>
            <div><p class="font-medium text-sm">Multi-Chain</p><p class="text-white/40 text-xs">Ethereum • BSC • Polygon</p></div>
          </div>
        </div>
      </div>

      <!-- Security Notice -->
      <div class="glass-card p-6">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-2xl bg-yellow-500/10 flex items-center justify-center text-yellow-500 text-2xl"><i class="fas fa-exclamation-triangle"></i></div>
          <div>
            <h3 class="font-semibold mb-1">Security Notice</h3>
            <p class="text-white/40 text-xs leading-relaxed">CryptoVault never stores your private keys. Connections are read-only. Never share your seed phrase.</p>
          </div>
        </div>
      </div>

      <!-- Live Feed -->
      <div class="glass-card p-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="live-dot"></span>
          <h3 class="text-sm font-semibold text-white/40 uppercase tracking-widest">Live Transactions</h3>
        </div>
        <div id="liveFeed" class="space-y-2 max-h-[250px] overflow-y-auto">
          <p class="text-white/30 text-sm text-center py-8">Waiting for new transactions...</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // === STATE ===
  let connectedAddress = null;
  let currentNativeSymbol = 'ETH';

  const NETWORKS = {
    ethereum: { chainId: '0x1', name: 'Ethereum', symbol: 'ETH', icon: 'fab fa-ethereum' },
    bsc:       { chainId: '0x38', name: 'BSC',       symbol: 'BNB', icon: 'fas fa-coins' },
    polygon:   { chainId: '0x89', name: 'Polygon',   symbol: 'MATIC', icon: 'fas fa-shapes' }
  };

  // Render network switch buttons
  function renderNetworkButtons() {
    const container = document.getElementById('networkButtons');
    container.innerHTML = '';
    Object.keys(NETWORKS).forEach(key => {
      const net = NETWORKS[key];
      const btn = document.createElement('button');
      btn.className = 'p-4 rounded-2xl bg-white/5 border border-white/10 hover:border-[#00ff88]/50 hover:bg-[#00ff88]/10 transition-all flex flex-col items-center gap-2';
      btn.innerHTML = `
        <i class="${net.icon} text-2xl"></i>
        <span class="text-xs font-medium">${net.name}</span>
      `;
      btn.onclick = () => switchNetwork(key);
      container.appendChild(btn);
    });
  }

  async function checkConnection() {
    try {
      const res = await fetch('/api/me');
      const data = await res.json();
      if (data.user?.walletAddress) {
        connectedAddress = data.user.walletAddress;
        showConnectedState(connectedAddress);
      }
    } catch (e) {}
  }

  function showConnectedState(address) {
    document.getElementById('walletConnectPanel').classList.add('hidden');
    document.getElementById('walletConnectedPanel').classList.remove('hidden');
    document.getElementById('walletAddress').textContent = address;

    renderNetworkButtons();

    if (window.ethereum) {
      const provider = new ethers.BrowserProvider(window.ethereum);
      updateBalanceAndNetwork(provider);
    }
  }

  async function updateBalanceAndNetwork(provider) {
    try {
      const bal = await provider.getBalance(connectedAddress);
      const formatted = parseFloat(ethers.formatEther(bal)).toFixed(4);
      document.getElementById('nativeBalance').textContent = `${formatted} ${currentNativeSymbol}`;

      const net = await provider.getNetwork();
      const networkName = net.name === 'unknown' ? 'Custom' : net.name;
      document.getElementById('currentNetwork').textContent = networkName;
      document.getElementById('balanceLabel').textContent = `${currentNativeSymbol} Balance`;
    } catch (e) {
      document.getElementById('nativeBalance').textContent = '—';
    }
  }

  async function connectMetaMask() {
    if (!window.ethereum) {
      showToast('MetaMask not detected. Please install it.', 'error');
      return;
    }
    const btn = event.currentTarget;
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.style.opacity = '0.7';

    try {
      const provider = new ethers.BrowserProvider(window.ethereum);
      const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
      const address = accounts[0];

      connectedAddress = address;
      currentNativeSymbol = 'ETH';

      const res = await fetch('/api/wallet/connect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ walletAddress: address, network: 'ethereum' })
      });

      if (res.ok) {
        showToast('✅ MetaMask connected!', 'success');
        showConnectedState(address);
      }
    } catch (err) {
      showToast(err.message || 'Connection failed', 'error');
    } finally {
      btn.disabled = false;
      btn.style.opacity = '1';
    }
  }

  async function connectWalletConnect() {
    showToast('WalletConnect v2 support coming soon. Use MetaMask for now.', 'info');
  }

  async function connectTrustWallet() {
    if (window.ethereum) await connectMetaMask();
    else showToast('Please open this page inside Trust Wallet.', 'error');
  }

  async function connectCoinbase() {
    if (window.ethereum?.isCoinbaseWallet) await connectMetaMask();
    else showToast('Coinbase Wallet not detected.', 'info');
  }

  async function switchNetwork(networkKey) {
    const net = NETWORKS[networkKey];
    if (!net || !window.ethereum) return;

    currentNativeSymbol = net.symbol;

    try {
      await window.ethereum.request({
        method: 'wallet_switchEthereumChain',
        params: [{ chainId: net.chainId }]
      });
      showToast(`Switched to ${net.name}`, 'success');
      const provider = new ethers.BrowserProvider(window.ethereum);
      await updateBalanceAndNetwork(provider);
    } catch (err) {
      if (err.code === 4902) {
        await window.ethereum.request({ method: 'wallet_addEthereumChain', params: [net] });
        showToast(`${net.name} added`, 'success');
      } else {
        showToast(err.message || 'Failed to switch network', 'error');
      }
    }
  }

  function copyAddress() {
    navigator.clipboard.writeText(connectedAddress).then(() => {
      showToast('Address copied to clipboard', 'success');
    });
  }

  async function disconnectWallet() {
    try {
      await fetch('/api/wallet/disconnect', { method: 'POST' });
    } catch (e) {}
    connectedAddress = null;
    document.getElementById('walletConnectPanel').classList.remove('hidden');
    document.getElementById('walletConnectedPanel').classList.add('hidden');
    showToast('Wallet disconnected', 'info');
  }

  // Account & chain listeners
  if (window.ethereum) {
    window.ethereum.on('accountsChanged', (accounts) => {
      if (accounts.length === 0) disconnectWallet();
      else {
        connectedAddress = accounts[0];
        showConnectedState(connectedAddress);
      }
    });

    window.ethereum.on('chainChanged', () => window.location.reload());
  }

  // Live feed (consistent with other pages)
  if (typeof socket !== 'undefined') {
    socket.on('new_transaction', (tx) => {
      const container = document.getElementById('liveFeed');
      if (container.querySelector('p')) container.innerHTML = '';

      const div = document.createElement('div');
      div.className = `tx-item flex items-center gap-3 p-3 rounded-2xl bg-white/5`;
      div.innerHTML = `
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium capitalize">${tx.type.replace('_', ' ')}</p>
          <p class="text-white/30 text-xs">${tx.amount ? tx.amount.toFixed(4) : ''} ${tx.token || ''} • ${new Date(tx.timestamp).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</p>
        </div>
        <span class="badge badge-confirmed text-xs px-3 py-1 rounded-2xl">LIVE</span>
      `;
      container.prepend(div);
      if (container.children.length > 12) container.lastChild.remove();
    });
  }

  // Init
  checkConnection();
  renderNetworkButtons();
</script>
