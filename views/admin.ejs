<!-- Admin Dashboard -->
<section class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-[#00ff88]/20 flex items-center justify-center text-[#00ff88]">
        <i class="fas fa-shield-alt"></i>
      </div>
      <div>
        <h1 class="text-2xl font-bold">Admin Dashboard</h1>
        <p class="text-white/40 text-sm">System overview and management</p>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <div class="glass-card px-4 py-2 flex items-center gap-2">
        <span class="live-dot"></span>
        <span class="text-sm font-mono"><span id="onlineCount"><%= onlineUsers %></span> Online</span>
      </div>
      <button onclick="toggleMaintenance()" class="btn-outline text-sm py-2 px-4 <%= maintenanceMode ? 'border-yellow-500/50 text-yellow-400' : '' %>">
        <i class="fas fa-wrench mr-1"></i> Maintenance <%= maintenanceMode ? 'ON' : 'OFF' %>
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8">
    <div class="glass-card p-6">
      <p class="text-white/40 text-xs uppercase tracking-widest mb-2">Total Users</p>
      <p class="text-3xl font-bold text-[#00ff88] font-mono"><%= users.length %></p>
    </div>
    <div class="glass-card p-6">
      <p class="text-white/40 text-xs uppercase tracking-widest mb-2">Wallets Linked</p>
      <p class="text-3xl font-bold text-[#00ff88] font-mono"><%= users.filter(u => u.walletAddress).length %></p>
    </div>
    <div class="glass-card p-6">
      <p class="text-white/40 text-xs uppercase tracking-widest mb-2">Transactions</p>
      <p class="text-3xl font-bold text-[#00ff88] font-mono"><%= transactions.length %></p>
    </div>
    <div class="glass-card p-6">
      <p class="text-white/40 text-xs uppercase tracking-widest mb-2">Online Now</p>
      <p class="text-3xl font-bold text-[#00ff88] font-mono" id="statsOnline"><%= onlineUsers %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Users Management -->
    <div class="lg:col-span-2 space-y-6">
      <div class="glass-card-strong p-6">
        <h2 class="text-lg font-semibold mb-6 flex items-center gap-2">
          <i class="fas fa-users text-[#00ff88]"></i> All Users
        </h2>
        <div class="overflow-x-auto">
          <table class="crypto-table w-full">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Wallet</th>
                <th>Portfolio</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(user => { %>
                <tr>
                  <td>
                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded-full bg-[#00ff88]/10 flex items-center justify-center text-xs text-[#00ff88] font-bold">
                        <%= user.name.charAt(0).toUpperCase() %>
                      </div>
                      <span class="text-sm font-medium"><%= user.name %></span>
                      <% if (user.isAdmin) { %>
                        <span class="badge badge-confirmed text-xs">Admin</span>
                      <% } %>
                    </div>
                  </td>
                  <td class="text-sm text-white/60"><%= user.email %></td>
                  <td class="font-mono text-xs text-white/40">
                    <%= user.walletAddress ? user.walletAddress.slice(0, 6) + '...' + user.walletAddress.slice(-4) : '—' %>
                  </td>
                  <td>
                    <div class="text-xs text-white/60">
                      <% Object.entries(user.portfolio || {}).forEach(([t, a]) => { %>
                        <span class="inline-block mr-2"><%= a.toFixed(2) %> <%= t %></span>
                      <% }) %>
                    </div>
                  </td>
                  <td>
                    <div class="flex gap-1">
                      <button onclick="openCreditModal('<%= user.id %>', '<%= user.name %>')" class="px-2 py-1 rounded bg-[#00ff88]/10 text-[#00ff88] text-xs hover:bg-[#00ff88]/20">
                        <i class="fas fa-plus"></i>
                      </button>
                      <button onclick="openDebitModal('<%= user.id %>', '<%= user.name %>')" class="px-2 py-1 rounded bg-red-500/10 text-red-400 text-xs hover:bg-red-500/20">
                        <i class="fas fa-minus"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- All Transactions -->
      <div class="glass-card-strong p-6">
        <h2 class="text-lg font-semibold mb-6 flex items-center gap-2">
          <i class="fas fa-list text-[#00ff88]"></i> All Transactions
        </h2>
        <div class="space-y-2 max-h-[400px] overflow-y-auto" id="allTransactions">
          <% transactions.forEach(tx => { %>
            <div class="tx-item <%= tx.type %>">
              <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-xs">
                <i class="fas fa-<%= tx.type === 'swap' ? 'exchange-alt' : tx.type === 'transfer' ? 'paper-plane' : tx.type === 'receive' ? 'download' : tx.type === 'admin_credit' ? 'plus' : tx.type === 'admin_debit' ? 'minus' : 'user-plus' %>"></i>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium capitalize"><%= tx.type.replace('_', ' ') %></span>
                  <span class="text-white/30 text-xs"><%= tx.userEmail || tx.from %></span>
                </div>
                <p class="text-white/30 text-xs">
                  <%= tx.amount ? tx.amount.toFixed(4) : '' %> <%= tx.token || '' %>
                  <% if (tx.toAmount) { %> → <%= tx.toAmount.toFixed(4) %> <%= tx.toToken %><% } %>
                  • <%= new Date(tx.timestamp).toLocaleString() %>
                </p>
              </div>
              <span class="badge badge-confirmed text-xs"><%= tx.status %></span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Announcement -->
      <div class="glass-card p-6">
        <h3 class="text-sm font-semibold text-white/40 uppercase tracking-widest mb-4">
          <i class="fas fa-bullhorn mr-1"></i> Global Announcement
        </h3>
        <textarea id="announceText" class="crypto-input mb-3" rows="3" placeholder="Type announcement..."></textarea>
        <button onclick="sendAnnouncement()" class="btn-accent w-full py-2">
          <i class="fas fa-paper-plane mr-1"></i> Broadcast
        </button>
      </div>

      <!-- Quick Stats -->
      <div class="glass-card p-6">
        <h3 class="text-sm font-semibold text-white/40 uppercase tracking-widest mb-4">Platform Activity</h3>
        <div class="space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-white/40">Swaps Today</span>
            <span class="font-mono"><%= transactions.filter(t => t.type === 'swap').length %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-white/40">Transfers</span>
            <span class="font-mono"><%= transactions.filter(t => t.type === 'transfer' || t.type === 'receive').length %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-white/40">Admin Actions</span>
            <span class="font-mono"><%= transactions.filter(t => t.type.startsWith('admin')).length %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-white/40">Signups</span>
            <span class="font-mono"><%= transactions.filter(t => t.type === 'signup').length %></span>
          </div>
        </div>
      </div>

      <!-- System Info -->
      <div class="glass-card p-6">
        <h3 class="text-sm font-semibold text-white/40 uppercase tracking-widest mb-4">System</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-white/40">Status</span>
            <span class="text-[#00ff88]">Operational</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white/40">Maintenance</span>
            <span class="<%= maintenanceMode ? 'text-yellow-400' : 'text-[#00ff88]' %>">
              <%= maintenanceMode ? 'Active' : 'Inactive' %>
            </span>
          </div>
          <div class="flex justify-between">
            <span class="text-white/40">Socket.io</span>
            <span class="text-[#00ff88]">Connected</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Credit Modal -->
<div id="creditModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden items-center justify-center">
  <div class="glass-card-strong p-6 max-w-sm w-full mx-4">
    <h3 class="text-lg font-bold mb-4">Credit Tokens</h3>
    <p class="text-white/40 text-sm mb-4">User: <span id="creditUserName" class="text-white"></span></p>
    <input type="hidden" id="creditUserId">
    <div class="mb-3">
      <label class="block text-white/40 text-xs uppercase tracking-widest mb-2">Token</label>
      <select id="creditToken" class="crypto-select w-full">
        <option value="BTC">BTC</option>
        <option value="ETH">ETH</option>
        <option value="SOL">SOL</option>
        <option value="USDC">USDC</option>
        <option value="USDT">USDT</option>
        <option value="BNB">BNB</option>
      </select>
    </div>
    <div class="mb-4">
      <label class="block text-white/40 text-xs uppercase tracking-widest mb-2">Amount</label>
      <input type="number" id="creditAmount" class="crypto-input" placeholder="0.00" step="0.000001">
    </div>
    <div class="flex gap-3">
      <button onclick="closeCreditModal()" class="flex-1 btn-outline py-2">Cancel</button>
      <button onclick="executeCredit()" class="flex-1 btn-accent py-2">Credit</button>
    </div>
  </div>
</div>

<!-- Debit Modal -->
<div id="debitModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden items-center justify-center">
  <div class="glass-card-strong p-6 max-w-sm w-full mx-4">
    <h3 class="text-lg font-bold mb-4">Debit Tokens</h3>
    <p class="text-white/40 text-sm mb-4">User: <span id="debitUserName" class="text-white"></span></p>
    <input type="hidden" id="debitUserId">
    <div class="mb-3">
      <label class="block text-white/40 text-xs uppercase tracking-widest mb-2">Token</label>
      <select id="debitToken" class="crypto-select w-full">
        <option value="BTC">BTC</option>
        <option value="ETH">ETH</option>
        <option value="SOL">SOL</option>
        <option value="USDC">USDC</option>
        <option value="USDT">USDT</option>
        <option value="BNB">BNB</option>
      </select>
    </div>
    <div class="mb-4">
      <label class="block text-white/40 text-xs uppercase tracking-widest mb-2">Amount</label>
      <input type="number" id="debitAmount" class="crypto-input" placeholder="0.00" step="0.000001">
    </div>
    <div class="flex gap-3">
      <button onclick="closeDebitModal()" class="flex-1 btn-outline py-2">Cancel</button>
      <button onclick="executeDebit()" class="flex-1 btn-accent py-2 bg-red-500 border-red-500 hover:bg-red-600">Debit</button>
    </div>
  </div>
</div>

<script>
  // Real-time stats
  socket.on('stats', (stats) => {
    document.getElementById('onlineCount').textContent = stats.onlineUsers;
    document.getElementById('statsOnline').textContent = stats.onlineUsers;
  });

  // New transactions
  socket.on('new_transaction', (tx) => {
    const container = document.getElementById('allTransactions');
    const div = document.createElement('div');
    div.className = `tx-item ${tx.type}`;
    const icon = tx.type === 'swap' ? 'exchange-alt' : tx.type === 'transfer' ? 'paper-plane' : tx.type === 'receive' ? 'download' : tx.type === 'admin_credit' ? 'plus' : tx.type === 'admin_debit' ? 'minus' : 'user-plus';
    div.innerHTML = `
      <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-xs">
        <i class="fas fa-${icon}"></i>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium capitalize">${tx.type.replace('_', ' ')}</span>
          <span class="text-white/30 text-xs">${tx.userEmail || tx.from}</span>
        </div>
        <p class="text-white/30 text-xs">${tx.amount ? tx.amount.toFixed(4) : ''} ${tx.token || ''} • ${new Date(tx.timestamp).toLocaleTimeString()}</p>
      </div>
      <span class="badge badge-confirmed text-xs">${tx.status}</span>
    `;
    container.prepend(div);
  });

  // Announcements
  socket.on('announcement', (ann) => {
    showToast(`Announcement: ${ann.message}`, 'info');
  });

  // Maintenance
  socket.on('maintenance', (data) => {
    showToast(data.enabled ? 'Maintenance mode enabled' : 'Maintenance mode disabled', 'info');
  });

  // Credit/Debit modals
  function openCreditModal(userId, name) {
    document.getElementById('creditUserId').value = userId;
    document.getElementById('creditUserName').textContent = name;
    document.getElementById('creditModal').classList.remove('hidden');
    document.getElementById('creditModal').classList.add('flex');
  }

  function closeCreditModal() {
    document.getElementById('creditModal').classList.add('hidden');
    document.getElementById('creditModal').classList.remove('flex');
  }

  function openDebitModal(userId, name) {
    document.getElementById('debitUserId').value = userId;
    document.getElementById('debitUserName').textContent = name;
    document.getElementById('debitModal').classList.remove('hidden');
    document.getElementById('debitModal').classList.add('flex');
  }

  function closeDebitModal() {
    document.getElementById('debitModal').classList.add('hidden');
    document.getElementById('debitModal').classList.remove('flex');
  }

  async function executeCredit() {
    const userId = document.getElementById('creditUserId').value;
    const token = document.getElementById('creditToken').value;
    const amount = parseFloat(document.getElementById('creditAmount').value);

    if (!amount || amount <= 0) {
      showToast('Enter a valid amount', 'error');
      return;
    }

    try {
      const res = await fetch('/api/admin/credit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, token, amount })
      });
      const data = await res.json();
      if (data.success) {
        showToast(`Credited ${amount} ${token}`, 'success');
        closeCreditModal();
        setTimeout(() => location.reload(), 500);
      } else {
        showToast(data.error, 'error');
      }
    } catch (err) {
      showToast('Failed to credit', 'error');
    }
  }

  async function executeDebit() {
    const userId = document.getElementById('debitUserId').value;
    const token = document.getElementById('debitToken').value;
    const amount = parseFloat(document.getElementById('debitAmount').value);

    if (!amount || amount <= 0) {
      showToast('Enter a valid amount', 'error');
      return;
    }

    try {
      const res = await fetch('/api/admin/debit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, token, amount })
      });
      const data = await res.json();
      if (data.success) {
        showToast(`Debited ${amount} ${token}`, 'success');
        closeDebitModal();
        setTimeout(() => location.reload(), 500);
      } else {
        showToast(data.error, 'error');
      }
    } catch (err) {
      showToast('Failed to debit', 'error');
    }
  }

  async function sendAnnouncement() {
    const message = document.getElementById('announceText').value.trim();
    if (!message) {
      showToast('Enter a message', 'error');
      return;
    }

    try {
      const res = await fetch('/api/admin/announce', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message })
      });
      const data = await res.json();
      if (data.success) {
        showToast('Announcement broadcasted!', 'success');
        document.getElementById('announceText').value = '';
      } else {
        showToast(data.error, 'error');
      }
    } catch (err) {
      showToast('Failed to send announcement', 'error');
    }
  }

  async function toggleMaintenance() {
    try {
      const res = await fetch('/api/admin/maintenance', { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        showToast(data.maintenanceMode ? 'Maintenance mode ON' : 'Maintenance mode OFF', 'info');
        setTimeout(() => location.reload(), 500);
      }
    } catch (err) {
      showToast('Failed to toggle maintenance', 'error');
    }
  }
</script>
